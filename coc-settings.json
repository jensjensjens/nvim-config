{
  "powershell.integratedConsole.showOnStartup": false,
  "languageserver": {
    "terraform": {
      "command": "terraform-ls",
      "args": [
        "serve"
      ],
      "filetypes": [
        "terraform",
        "tf"
      ],
      "initializationOptions": {}
    },
    "dockerfile": {
      "command": "docker-langserver",
      "filetypes": [
        "dockerfile"
      ],
      "args": [
        "--stdio"
      ]
    },
    "bicep": {
      "command": "dotnet",
      "args": [
        "/usr/local/bin/bicep-langserver/Bicep.LangServer.dll"
      ],
      "filetypes": [
        "bicep"
      ]
    }
  }
}
